    <template id="report_template_workorder">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="coenta_mrp_product_template.report_work_order_document"/>
            </t>
        </t>
    </template>

    <template id="report_mrp_product_teplate_document">
        <t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout">
                <t t-foreach="doc.workorder_template_ids" t-as="o">
                    <t t-set="o" t-value="o.with_context()"/>
                    <div class="page">
                        <style>
                            .table-bordered > thead > tr > th,
                            .table-bordered > tbody > tr > th,
                            .table-bordered > tfoot > tr > th,
                            .table-bordered > thead > tr > td,
                            .table-bordered > tbody > tr > td,
                            .table-bordered > tfoot > tr > td {
                            border: 1px solid #000000;
                            }
                        </style>
                        <div class="row">
                            <div class="col-12">
                                <table class="table table-bordered"
                                       style="vertical-align:middle; font-size:10pt; text-align:left">
                                    <thead>
                                        <tr>
                                            <th class="col-xs-3">
                                                Manufacture Order
                                            </th>
                                            <th class="col-xs-3">
                                                Production note
                                            </th>
                                            <th class="col-xs-3">
                                                Product
                                            </th>
                                            <th class="col-xs-3">
                                                Work Center
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>
                                                <span t-field="o.mrp_template_id.name"/>
                                            </td>
                                            <td>
                                                <span t-field="o.name"/>
                                            </td>
                                            <td>
                                                <span t-field="o.mrp_template_id.product_tmpl_id.name"/>
                                            </td>
                                            <td>
                                                <span t-field="o.operation_id.workcenter_id"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <table class="table table-bordered"
                                       style="vertical-align:middle; font-size:10pt; text-align:left">
                                    <thead>
                                        <tr style="background-color: #f2f2f2;font-size:bold;">
                                            <th>Product</th>
                                            <th>Quantity</th>
                                            <th>UOM</th>
                                            <th>Duration</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="o.workorder_ids" t-as="workorder">
                                            <t t-set="production" t-value="workorder.production_id"/>
                                            <tr style="background-color: #000000;color:white;font-size:bold;">
                                                <td>
                                                    <span t-field="production.product_id.display_name"/>
                                                </td>
                                                <td>
                                                    <span t-field="production.qty_producing"/>
                                                </td>
                                                <td>
                                                    <span t-field="production.product_uom_id.name"/>
                                                </td>
                                                <td>
                                                    <span t-field="workorder.duration"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td colspan="4">


                                                    <table class="table table-bordered"
                                                           style="vertical-align:middle; font-size:10pt; text-align:left">
                                                        <thead>
                                                            <tr>
                                                                <th>Product</th>
                                                                <th>Quantity</th>
                                                                <th>UOM</th>
                                                                <th>Lot</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <t t-foreach="production.move_raw_ids" t-as="raw">
                                                                <tr>
                                                                    <td>
                                                                        <span t-field="raw.product_id.name"/>
                                                                    </td>
                                                                    <td>
                                                                        <span t-field="raw.product_uom_qty"/>
                                                                    </td>
                                                                    <td>
                                                                        <span t-field="raw.quantity_done"/>
                                                                    </td>
                                                                    <td>
                                                                        <span t-field="raw.lot_ids"/>
                                                                    </td>
                                                                </tr>
                                                            </t>
                                                        </tbody>
                                                    </table>
                                                </td>
                                            </tr>
                                            <tr>

                                            </tr>
                                        </t>

                                    </tbody>

                                </table>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_mrp_product_teplate">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="coenta_mrp_product_template.report_mrp_product_teplate_document"/>
            </t>
        </t>
    </template>
</odoo>
