                                </t>

                            </tbody>

                        </table>
                    </div>
                </div>

            </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_mrp_product_teplate">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="coenta_mrp_product_template.report_mrp_product_teplate_document"/>
            </t>
        </t>
    </template>
</odoo>
